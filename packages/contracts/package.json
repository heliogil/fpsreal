{
  "name": "@pcb/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript contracts for pc-builder-br (Rei do FPS) — entities, repository interfaces, wizard flow, and FastAPI request/response types. Shared between frontend and backend with mock-first support.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./entities": {
      "types": "./src/entities.ts",
      "default": "./src/entities.ts"
    },
    "./repositories": {
      "types": "./src/repositories.ts",
      "default": "./src/repositories.ts"
    },
    "./wizard": {
      "types": "./src/wizard.ts",
      "default": "./src/wizard.ts"
    },
    "./api": {
      "types": "./src/api.ts",
      "default": "./src/api.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}